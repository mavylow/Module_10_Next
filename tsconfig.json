{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@app*": ["src/app/*"],
      "@components/*": ["src/app/_components/*"],
      "@assets/*": ["src/app/_assets/*"],
      "@utils/*": ["src/utils/*"],
      "@store/*": ["src/store/*"],
      "@slices/*": ["src/slices/*"],
      "@providers/*": ["src/providers/*"],
      "@auth/*": ["src/app/(pages)/(auth)/*"],
      "@pages/*": ["src/app/(pages)/*"],
      "@tests/*": ["src/tests/*"]

    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "**/*.ts",
    "**/*.tsx"
, "src/app/page.js", "src/app/_components/ClientsInit"  ],
  "exclude": ["node_modules"]
}
